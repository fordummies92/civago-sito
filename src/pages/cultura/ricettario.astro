const categorie = [
  { slug: "tutti", label: "Tutte" },
  { slug: "primo", label: "🍜 Primi" },
  { slug: "secondo", label: "🍖 Secondi" },
  { slug: "dolce", label: "🍰 Dolci" },
  { slug: "pane", label: "🍞 Pane" },
  { slug: "antipasto", label: "🥗 Antipasti" },
  { slug: "condimento", label: "🧀 Condimenti" },
  { slug: "altro", label: "🌰 Altro" },
];
---

<Layout title="Ricettario" description="19 ricette tradizionali di Civago: Bazzina, Necci, Vinada, Gnuclin d'castegn e molto altro.">

  <div style="background:var(--marrone-scuro)" class="py-16 px-4 text-white">
    <div class="max-w-6xl mx-auto">
      <a href="/cultura" class="text-white/60 text-sm hover:text-white mb-3 block">← Cultura & Tradizioni</a>
      <div class="badge mb-3" style="background:rgba(255,255,255,0.15);color:white">🍄 Cucina tradizionale</div>
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-3">Ricettario</h1>
      <p class="text-white/75 text-lg max-w-xl">
        19 ricette dell'Alto Appennino emiliano tramandate di generazione in generazione.
        Castagne, patate, forno a legna: la cucina povera e saporita di Civago.
      </p>
    </div>
  </div>

  <div class="max-w-6xl mx-auto px-4 py-10">

    <!-- Ricerca + Filtri -->
    <div class="mb-8">
      <input
        type="text"
        id="cerca-ricetta"
        class="search-input mb-5"
        placeholder="🔍 Cerca una ricetta… (es. castagne, patate, forno a legna)"
      />
      <div class="flex flex-wrap gap-2" id="filtri-categoria">
        {categorie.map(c => (
          <button
            class="filtro-cat px-4 py-2 rounded-full text-sm font-medium transition-all"
            data-cat={c.slug}
          >
            {c.label}
          </button>
        ))}
      </div>
    </div>

    <!-- Griglia ricette -->
    <div id="griglia-ricette" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {ricette.map(r => (
        <div
          class="card ricetta-card group cursor-pointer"
          data-cat={r.categoria}
          data-nome={r.nome.toLowerCase()}
          data-desc={r.desc.toLowerCase()}
          data-ingredienti={r.ingredienti.join(' ').toLowerCase()}
        >
          <div class="p-6">
            <div class="flex items-start justify-between mb-3">
              <span class="text-4xl">{r.emoji}</span>
              <span class="badge">{r.categoria}</span>
            </div>
            <h3 class="font-bold text-lg mb-1 group-hover:underline" style="color:var(--marrone-scuro)">{r.nome}</h3>
            <div class="text-xs text-stone-400 mb-2">👥 {r.dosi}</div>
            <p class="text-sm text-stone-500 leading-relaxed mb-4">{r.desc}</p>

            <!-- Ingredienti (collapsible) -->
            <details class="group/det">
              <summary class="cursor-pointer text-sm font-semibold select-none" style="color:var(--verde-salvia)">
                📝 Ingredienti & procedimento
              </summary>
              <div class="mt-3 border-t border-stone-100 pt-3">
                <h4 class="text-xs font-bold uppercase tracking-wider text-stone-400 mb-2">Ingredienti</h4>
                <ul class="text-sm text-stone-600 space-y-1 mb-4">
                  {r.ingredienti.map(i => <li class="flex gap-2"><span class="text-stone-300">·</span>{i}</li>)}
                </ul>
                <h4 class="text-xs font-bold uppercase tracking-wider text-stone-400 mb-2">Procedimento</h4>
                <div class="text-sm text-stone-600 leading-relaxed whitespace-pre-line">{r.procedimento}</div>
              </div>
            </details>
          </div>
        </div>
      ))}
    </div>

    <div id="nessun-risultato" class="hidden text-center py-12 text-stone-400">
      <div class="text-4xl mb-3">🔍</div>
      <p>Nessuna ricetta trovata. Prova con un altro termine.</p>
    </div>

  </div>
</Layout>

<style>
.filtro-cat {
  background: white;
  border: 1.5px solid var(--beige-scuro);
  color: var(--testo-muted);
}
.filtro-cat.active {
  background: var(--marrone);
  border-color: var(--marrone);
  color: white;
}
.filtro-cat:hover:not(.active) {
  border-color: var(--marrone);
  color: var(--marrone-scuro);
}
.ricetta-card.nascosta { display: none; }
</style>

<script>
const cerca = document.getElementById('cerca-ricetta') as HTMLInputElement;
const filtriBtn = document.querySelectorAll('.filtro-cat');
let catAttiva = 'tutti';

// Imposta "Tutte" come attivo di default
document.querySelector('[data-cat="tutti"]')?.classList.add('active');

function filtra() {
  const testo = cerca?.value.toLowerCase() ?? '';
  let visibili = 0;
  document.querySelectorAll('.ricetta-card').forEach(card => {
    const el = card as HTMLElement;
    const matchCat = catAttiva === 'tutti' || el.dataset.cat === catAttiva;
    const matchTesto = !testo ||
      el.dataset.nome?.includes(testo) ||
      el.dataset.desc?.includes(testo) ||
      el.dataset.ingredienti?.includes(testo);
    if (matchCat && matchTesto) {
      el.classList.remove('nascosta');
      visibili++;
    } else {
      el.classList.add('nascosta');
    }
  });
  const nessuno = document.getElementById('nessun-risultato');
  if (nessuno) nessuno.classList.toggle('hidden', visibili > 0);
}

cerca?.addEventListener('input', filtra);

filtriBtn.forEach(btn => {
  btn.addEventListener('click', () => {
    filtriBtn.forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    catAttiva = (btn as HTMLElement).dataset.cat ?? 'tutti';
    filtra();
  });
});
</script>
