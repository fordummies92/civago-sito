---
import Layout from '../../layouts/Layout.astro';

const ricette = [
  {
    slug: "bazzina",
    nome: "Bazzina o Manufatt",
    categoria: "primo",
    emoji: "🫕",
    desc: "Minestrone ricco con farina di granturco. Il piatto invernale per eccellenza, versione morbida della polenta.",
