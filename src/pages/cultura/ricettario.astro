    ingredienti: ["Pasta: 1 kg farina, ½ lt latte, 1 bicchiere olio, 1 cubetto lievito", "Ripieno: 1 kg riso, 6 uova, ½ kg ricotta, 200 g pecorino, 200 g parmigiano, sale, pepe"],
    procedimento: "Cuocere il riso in acqua e latte, lasciare riposare 12 ore.\nStendere la pasta sfoglia in teglia oleata coprendo bene i bordi.\nMescolare il riso con tutti gli altri ingredienti, stendere sulla sfoglia.\nRipiegare ~1 cm di pasta sul ripieno, decorare con i 'Pizz'.\nInfornare.",
    dosi: "10 persone",
  },
  {
    slug: "vinada",
    nome: "Vinada",
    categoria: "dolce",
    emoji: "🍷",
    desc: "Farina di castagne sciolta in vino rosso caldo. Il piatto dei boscaioli, la sera d'inverno.",
    ingredienti: ["500 g farina di castagne", "1 lt vino rosso", "500 ml acqua"],
