---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
}

const { title, description = "Civago — la perla verde dell'Alto Appennino emiliano", image } = Astro.props;
const currentPath = Astro.url.pathname;

const nav = [
  { label: "Scopri", href: "/scopri" },
  { label: "Esplora", href: "/esplora" },
  { label: "Cultura", href: "/cultura" },
  { label: "Foto", href: "/foto" },
  { label: "Comunità", href: "/comunita" },
];
---

<!doctype html>
<html lang="it">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta property="og:title" content={`${title} | Civago`} />
  <meta property="og:description" content={description} />
  {image && <meta property="og:image" content={image} />}
  <title>{title} | Civago</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <!-- Leaflet per mappa -->
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
</head>
<body>

  <!-- NAVBAR -->
  <header class="sticky top-0 z-50 bg-white/95 backdrop-blur border-b border-stone-200 shadow-sm">
    <div class="max-w-6xl mx-auto px-4 h-16 flex items-center justify-between">

      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 no-underline">
        <span class="text-2xl">🌲</span>
        <div>
          <div class="font-bold text-lg leading-tight" style="color:var(--verde-bosco)">Civago</div>
          <div class="text-xs leading-tight" style="color:var(--testo-muted)">Alto Appennino Reggiano</div>
        </div>
      </a>

      <!-- Nav desktop -->
      <nav class="hidden md:flex items-center gap-7">
        {nav.map(n => (
          <a
            href={n.href}
            class={`nav-link pb-0.5 ${currentPath.startsWith(n.href) ? 'border-b-2' : ''}`}
            style={currentPath.startsWith(n.href) ? 'border-color:var(--verde-salvia);color:var(--verde-salvia)' : ''}
          >
            {n.label}
          </a>
        ))}
        <a href="/comunita#news" class="btn-primary text-sm py-2 px-4">
          📢 News
        </a>
      </nav>

      <!-- Hamburger mobile -->
      <button id="hamburger" class="md:hidden p-2 rounded-lg" style="color:var(--verde-bosco)" aria-label="Menu">
        <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="3" y1="6" x2="21" y2="6"/>
          <line x1="3" y1="12" x2="21" y2="12"/>
          <line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
      </button>
    </div>

    <!-- Mobile menu -->
    <div id="mobile-menu" class="md:hidden border-t border-stone-200 bg-white px-4 py-4">
      {nav.map(n => (
        <a href={n.href} class="block py-2.5 nav-link text-base border-b border-stone-100 last:border-0">
          {n.label}
        </a>
      ))}
    </div>
  </header>

  <!-- CONTENUTO PAGINA -->
  <main>
    <slot />
  </main>

  <!-- FOOTER -->
  <footer class="mt-20 py-12 px-4">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-10">

        <div>
          <div class="flex items-center gap-2 mb-3">
            <span class="text-2xl">🌲</span>
            <span class="font-bold text-xl text-white">Civago</span>
          </div>
          <p class="text-sm opacity-75 leading-relaxed">
            La perla verde dell'Alto Appennino emiliano.<br/>
            Comune di Villaminozzo, Reggio Emilia.
          </p>
        </div>

        <div>
          <h4 class="text-white font-semibold mb-3">Sezioni</h4>
          <ul class="space-y-2 text-sm opacity-80">
            {nav.map(n => (
              <li><a href={n.href} class="hover:text-white transition-colors">{n.label}</a></li>
            ))}
          </ul>
        </div>

        <div>
          <h4 class="text-white font-semibold mb-3">Contatti</h4>
          <div class="text-sm opacity-80 space-y-2">
            <p>📧 <a href="mailto:info@civago.it" class="hover:text-white">info@civago.it</a></p>
            <p>🌐 <a href="https://www.civago.it" class="hover:text-white">www.civago.it</a></p>
            <p class="mt-4 opacity-60 text-xs">
              © {new Date().getFullYear()} Civago — Tutti i diritti riservati
            </p>
          </div>
        </div>

      </div>
    </div>
  </footer>

  <script>
    // Mobile menu toggle
    const btn = document.getElementById('hamburger');
    const menu = document.getElementById('mobile-menu');
    btn?.addEventListener('click', () => menu?.classList.toggle('open'));
  </script>

</body>
</html>
